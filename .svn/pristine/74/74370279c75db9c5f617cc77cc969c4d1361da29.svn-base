        ),
		array(
            'label' => 'Branch',
            'value' => $branch->name,
        ),
		array(
            'label' => 'Penjualan #',
            'value' => $sale->getCodeNumber(SaleHeader::CN_CONSTANT),
        ),
        array(
            'label' => 'Customer',
            'value' => $sale->customer->company,
        ),
        array(
            'label' => 'Catatan',
            'value' => $delivery->note,
        ),
    ),
));
?>

<?php
$this->widget('zii.widgets.grid.CGridView', array(
    'id' => 'delivery-detail-grid',
    'dataProvider' => $detailsDataProvider,
    'columns' => array(
        array(
