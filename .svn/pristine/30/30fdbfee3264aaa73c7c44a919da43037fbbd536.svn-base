<?php

/**
 * @property integer $id
 * @property integer $cn_ordinal
 * @property integer $cn_month
 * @property integer $cn_year
 * @property string $date
 * @property string $note
 * @property string $status
 * @property integer $purchase_receipt_header_id
 * @property integer $admin_id
 * @property integer $branch_id
 * @property integer $is_using_cheque
 * @property integer $is_non_tax
 * @property integer $is_inactive
 *
 * @property PurchasePaymentDetail[] $purchasePaymentDetails
 * @property Branch $branch
 * @property Admin $admin
 * @property PurchaseReceiptHeader $purchaseReceiptHeader
 */
class PurchasePaymentHeaderBase extends MonthlyTransactionActiveRecord {

    public function tableName() {
        return 'tblla_purchase_payment_header';
    }

    public function rules() {
        return array(
            array('cn_ordinal, cn_month, cn_year, date, purchase_receipt_header_id, admin_id, branch_id, is_using_cheque', 'required'),
            array('cn_ordinal, cn_month, cn_year, purchase_receipt_header_id, admin_id, branch_id, is_non_tax, is_using_cheque, is_inactive', 'numerical', 'integerOnly' => true),
            array('status', 'length', 'max'=>60),
            array('note', 'safe'),
            // The following rule is used by search().
            array('id, cn_ordinal, cn_month, cn_year, date, note, status, purchase_receipt_header_id, admin_id, branch_id, is_non_tax, is_using_cheque, is_inactive', 'safe', 'on' => 'search'),
        );
    }

    public function relations() {
        return array(
            'purchasePaymentDetails' => array(self::HAS_MANY, 'PurchasePaymentDetail', 'purchase_payment_header_id'),
            'branch' => array(self::BELONGS_TO, 'Branch', 'branch_id'),
            'admin' => array(self::BELONGS_TO, 'Admin', 'admin_id'),
            'purchaseReceiptHeader' => array(self::BELONGS_TO, 'PurchaseReceiptHeader', 'purchase_receipt_header_id'),
        );
    }

    public function attributeLabels() {
        return array(
            'id' => 'ID',
            'cn_ordinal' => 'Cn Ordinal',
            'cn_month' => 'Cn Month',
            'cn_year' => 'Cn Year',
            'date' => 'Date',
            'note' => 'Note',
            'purchase_receipt_header_id' => 'Purchase Receipt Header',
            'admin_id' => 'Admin',
            'branch_id' => 'Branch',
            'is_non_tax' => 'Is Non Tax',
            'is_inactive' => 'Is Inactive',
        );
    }

    public function search() {
        $criteria = new CDbCriteria;

        $criteria->compare('id', $this->id);
        $criteria->compare('t.cn_ordinal', $this->cn_ordinal);
        $criteria->compare('t.cn_month', $this->cn_month);
        $criteria->compare('t.cn_year', $this->cn_year);
        $criteria->compare('t.date', $this->date, true);
        $criteria->compare('note', $this->note, true);
        $criteria->compare('status', $this->status, true);
        $criteria->compare('purchase_receipt_header_id', $this->purchase_receipt_header_id);
        $criteria->compare('admin_id', $this->admin_id);
        $criteria->compare('branch_id', $this->branch_id);
        $criteria->compare('is_non_tax', $this->is_non_tax);
        $criteria->compare('is_using_cheque', $this->is_using_cheque);
        $criteria->compare('t.is_inactive', $this->is_inactive);

        return new CActiveDataProvider($this, array(
            'criteria' => $criteria,
        ));
    }
}
