<?php

/**
 * @property integer $id
 * @property integer $cn_ordinal
 * @property integer $cn_month
 * @property integer $cn_year
 * @property string $date
 * @property string $date_approval
 * @property string $note
 * @property integer $account_id
 * @property integer $branch_id
 * @property integer $admin_id
 * @property integer $admin_id_approval
 * @property integer $is_bank
 * @property integer $is_non_tax
 * @property integer $is_approved
 * @property integer $is_inactive
 *
 * @property ExpenseDetail[] $expenseDetails
 * @property Account $account
 * @property Admin $admin
 * @property Branch $branch
 */
class ExpenseHeaderBase extends MonthlyTransactionActiveRecord
{
	public function tableName()
	{
		return 'tblla_expense_header';
	}

	public function rules()
	{
		return array(
			array('cn_ordinal, cn_month, cn_year, date, account_id, branch_id, admin_id', 'required'),
			array('cn_ordinal, cn_month, cn_year, account_id, branch_id, admin_id, admin_id_approval, is_bank, is_non_tax, is_approved, is_inactive', 'numerical', 'integerOnly'=>true),
			array('date_approval, note', 'safe'),
			// The following rule is used by search().
			array('id, cn_ordinal, cn_month, cn_year, date, date_approval, note, account_id, branch_id, admin_id, admin_id_approval, is_bank, is_non_tax, is_approved, is_inactive', 'safe', 'on'=>'search'),
		);
	}

	public function relations()
	{
		return array(
			'expenseDetails' => array(self::HAS_MANY, 'ExpenseDetail', 'expense_header_id'),
			'account' => array(self::BELONGS_TO, 'Account', 'account_id'),
			'admin' => array(self::BELONGS_TO, 'Admin', 'admin_id'),
			'branch' => array(self::BELONGS_TO, 'Branch', 'branch_id'),
		);
	}

	public function attributeLabels()
	{
		return array(
			'id' => 'ID',
			'cn_ordinal' => 'Cn Ordinal',
			'cn_month' => 'Cn Month',
			'cn_year' => 'Cn Year',
			'date' => 'Date',
			'date_approval' => 'Date Approval',
			'note' => 'Note',
			'account_id' => 'Account',
			'branch_id' => 'Branch',
			'admin_id' => 'Admin',
			'admin_id_approval' => 'Admin Id Approval',
			'is_bank' => 'Is Bank',
			'is_non_tax' => 'Is Non Tax',
			'is_approved' => 'Is Approved',
			'is_inactive' => 'Is Inactive',
		);
	}

	public function search()
	{
		$criteria = new CDbCriteria;

		$criteria->compare('t.id', $this->id);
		$criteria->compare('t.cn_ordinal', $this->cn_ordinal);
		$criteria->compare('t.cn_month', $this->cn_month);
		$criteria->compare('t.cn_year', $this->cn_year);
		$criteria->compare('t.date', $this->date, true);
		$criteria->compare('t.date_approval', $this->date_approval, true);
		$criteria->compare('t.note', $this->note, true);
		$criteria->compare('t.account_id', $this->account_id);
		$criteria->compare('t.branch_id', $this->branch_id);
		$criteria->compare('t.admin_id', $this->admin_id);
		$criteria->compare('t.admin_id_approval', $this->admin_id_approval);
		$criteria->compare('t.is_bank', $this->is_bank);
		$criteria->compare('t.is_non_tax', $this->is_non_tax);
		$criteria->compare('t.is_approved', $this->is_approved);
		$criteria->compare('t.is_inactive', $this->is_inactive);

		return new CActiveDataProvider($this, array(
			'criteria'=>$criteria,
		));
	}
}