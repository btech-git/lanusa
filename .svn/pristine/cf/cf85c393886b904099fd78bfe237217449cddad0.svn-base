	<tr>
		<td  colspan="4" style="text-align: right; border-left: 2px solid; border-right:1px solid; font-weight: bold">PPN. <?php echo CHtml::encode(CHtml::value($sale, 'tax')); ?>%</td>
		<td style="border-right:1px solid; font-weight: bold; text-align: right; text-align: right"><?php echo CHtml::encode(Yii::app()->numberFormatter->format('#,##0.00', CHtml::value($sale, 'calculatedTax'))); ?></td>
	</tr>
	<tr>
		<td  colspan="4" style="border-left:2px solid; border-top: 2px solid; border-right:1px solid; font-weight: bold; text-align: right">Grand Total</td>
		<td style="border-top:2px solid; border-right:1px solid; font-weight: bold; text-align: right"><?php echo CHtml::encode(Yii::app()->numberFormatter->format('#,##0.00', CHtml::value($sale, 'grandTotal'))); ?></td>
