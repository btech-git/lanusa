<table>
    <tr>
        <td style="width:80% ;text-align: right; font-weight: bold">Total Quantity</td>
        <td style="width:20% ;text-align: right; font-weight: bold"><?php echo CHtml::encode(Yii::app()->numberFormatter->format('#,##0', CHtml::value($sale, 'totalQuantity'))); ?></td>
