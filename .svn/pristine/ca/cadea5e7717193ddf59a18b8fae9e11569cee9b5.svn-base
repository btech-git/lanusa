    <tr>
        <td style="text-align: right; font-weight: bold">Ongkos Kirim</td>
        <td style="text-align: right; font-weight: bold"><?php echo CHtml::encode(Yii::app()->numberFormatter->format('#,##0.00', CHtml::value($sale, 'shipping_fee'))); ?></td>
    </tr>
    <tr>
        <td style="text-align: right; font-weight: bold">Grand Total</td>
        <td style="text-align: right; font-weight: bold"><?php echo CHtml::encode(Yii::app()->numberFormatter->format('#,##0.00', CHtml::value($sale, 'grandTotal'))); ?></td>
