<?php

/**
 * @property integer $id
 * @property string $quantity
 * @property integer $receive_header_id
 * @property integer $product_id
 * @property integer $warehouse_id
 * @property integer $purchase_detail_id
 * @property integer $is_inactive
 *
 * @property PurchaseDetail $purchaseDetail
 * @property Product $product
 * @property ReceiveHeader $receiveHeader
 * @property Warehouse $warehouse
 */
class ReceiveDetailBase extends ActiveRecord
{
	public function tableName()
	{
		return 'tblla_receive_detail';
	}

	public function rules()
	{
		return array(
			array('receive_header_id, product_id, warehouse_id, purchase_detail_id', 'required'),
			array('receive_header_id, product_id, warehouse_id, purchase_detail_id, is_inactive', 'numerical', 'integerOnly'=>true),
			array('quantity', 'length', 'max'=>10),
			// The following rule is used by search().
			array('id, quantity, receive_header_id, product_id, warehouse_id, purchase_detail_id, is_inactive', 'safe', 'on'=>'search'),
		);
	}

	public function relations()
	{
		return array(
			'purchaseDetail' => array(self::BELONGS_TO, 'PurchaseDetail', 'purchase_detail_id'),
			'product' => array(self::BELONGS_TO, 'Product', 'product_id'),
			'receiveHeader' => array(self::BELONGS_TO, 'ReceiveHeader', 'receive_header_id'),
			'warehouse' => array(self::BELONGS_TO, 'Warehouse', 'warehouse_id'),
		);
	}

	public function attributeLabels()
	{
		return array(
			'id' => 'ID',
			'quantity' => 'Quantity',
			'receive_header_id' => 'Receive Header',
			'product_id' => 'Product',
			'warehouse_id' => 'Warehouse',
			'purchase_detail_id' => 'Purchase Detail',
			'is_inactive' => 'Is Inactive',
		);
	}

	public function search()
	{
		$criteria = new CDbCriteria;

		$criteria->compare('t.id', $this->id);
		$criteria->compare('t.quantity', $this->quantity, true);
		$criteria->compare('t.receive_header_id', $this->receive_header_id);
		$criteria->compare('t.product_id', $this->product_id);
		$criteria->compare('t.warehouse_id', $this->warehouse_id);
		$criteria->compare('t.purchase_detail_id', $this->purchase_detail_id);
		$criteria->compare('t.is_inactive', $this->is_inactive);

		return new CActiveDataProvider($this, array(
			'criteria'=>$criteria,
		));
	}
}